#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LOG_DIR="$ROOT_DIR/logs"

mkdir -p "$LOG_DIR"

stop_processes() {
  pkill -f "npm run dev -w backend" 2>/dev/null || true
  pkill -f "npm run dev -w frontend" 2>/dev/null || true
  pkill -f "backend/src/server.js" 2>/dev/null || true
  pkill -f "vite" 2>/dev/null || true
}

start() {
  stop_processes

  (cd "$ROOT_DIR" && setsid npm run dev -w backend > "$LOG_DIR/backend.log" 2>&1 < /dev/null &)
  (cd "$ROOT_DIR" && setsid npm run dev -w frontend > "$LOG_DIR/frontend.log" 2>&1 < /dev/null &)

  echo "Baustellen-Darstellung gestartet."
  status
}

stop() {
  stop_processes
  echo "Baustellen-Darstellung gestoppt."
}

status() {
  local backend_count frontend_count
  backend_count=$(pgrep -fc "npm run dev -w backend|backend/src/server.js" || true)
  frontend_count=$(pgrep -fc "npm run dev -w frontend|vite" || true)

  if [[ "$backend_count" -gt 0 && "$frontend_count" -gt 0 ]]; then
    echo "Status: läuft"
    echo "User-Ansicht: http://$(hostname -I | awk '{print $1}'):5173"
    echo "TV-Ansicht:   http://$(hostname -I | awk '{print $1}'):5173/tv"
  else
    echo "Status: gestoppt"
  fi
}

restart() {
  stop
  sleep 1
  start
}

case "${1:-}" in
  start) start ;;
  stop) stop ;;
  restart) restart ;;
  status) status ;;
  *)
    echo "Verwendung: $(basename "$0") {start|stop|restart|status}"
    exit 1
    ;;
esac
